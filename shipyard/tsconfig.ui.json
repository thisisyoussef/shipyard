{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"]
  },
  "include": [
    "vite.config.ts",
    "ui/**/*.d.ts",
    "ui/**/*.ts",
    "ui/**/*.tsx",
    "src/ui/**/*.ts"
  ]
}
