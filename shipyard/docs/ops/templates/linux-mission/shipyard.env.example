# Shipyard hosted runtime
SHIPYARD_ACCESS_TOKEN=replace-with-a-long-random-secret
SHIPYARD_HOSTED_URL=https://shipyard.example.com
SHIPYARD_TARGETS_DIR=/srv/workspace
SHIPYARD_REQUIRE_PERSISTENT_WORKSPACE=1
SHIPYARD_MODEL_PROVIDER=anthropic
SHIPYARD_ANTHROPIC_MODEL=claude-opus-4-6

# Provider credentials
ANTHROPIC_API_KEY=replace-me
OPENAI_API_KEY=
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=shipyard-production
LANGCHAIN_TRACING_V2=true

# Optional source-control integration
GITHUB_TOKEN=

# Mission watchdog
MISSION_CONFIG_PATH=/srv/workspace/ship-promptpack-ultimate/.shipyard/ops/__SESSION_ID__/mission.config.json

# Backup Vercel deploy sync
TARGET_DIR=/srv/workspace/ship-promptpack-ultimate
TARGET_BUILD_COMMAND=npm run build
TARGET_BUILD_FALLBACK_COMMAND=npx vite build
TARGET_OUTPUT_DIR=dist
VERCEL_TOKEN=replace-me
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_SYNC_STATE_DIR=/srv/workspace/ship-promptpack-ultimate/.shipyard/ops/__SESSION_ID__/vercel-sync
