{
  "name": "shipyard",
  "version": "0.1.0",
  "private": true,
  "description": "Persistent coding agent foundation for Shipyard",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "bin": {
    "shipyard": "./dist/bin/shipyard.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --env-file=.env --import tsx ./src/bin/shipyard.ts",
    "start": "node --env-file=.env --import tsx ./src/bin/shipyard.ts",
    "shipyard": "node --env-file=.env --import tsx ./src/bin/shipyard.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.5",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "langsmith": "^0.5.13",
    "nanoid": "^5.1.7",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  }
}
