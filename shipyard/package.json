{
  "name": "shipyard",
  "version": "0.1.0",
  "private": true,
  "description": "Persistent coding agent foundation for Shipyard",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "bin": {
    "shipyard": "./dist/bin/shipyard.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:ui": "vite build",
    "dev": "node --env-file-if-exists=.env --import tsx ./src/bin/shipyard.ts",
    "manual:spec-pack": "node --env-file-if-exists=.env --import tsx ./tests/manual/spec-pack-rebuild.ts",
    "start": "node --env-file-if-exists=.env --import tsx ./src/bin/shipyard.ts",
    "shipyard": "node --env-file-if-exists=.env --import tsx ./src/bin/shipyard.ts",
    "test-target:init": "bash ../scripts/init-test-target.sh",
    "test-target:cli": "node --env-file-if-exists=.env --import tsx ./src/bin/shipyard.ts --target ../test-targets/tic-tac-toe",
    "test-target:ui": "node --env-file-if-exists=.env --import tsx ./src/bin/shipyard.ts --target ../test-targets/tic-tac-toe --ui",
    "test:smoke": "vitest run tests/cli-loop.test.ts tests/tooling.test.ts tests/context-envelope.test.ts tests/turn-runtime.test.ts tests/graph-runtime.test.ts tests/ui-runtime.test.ts tests/langsmith-tracing.test.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.ui.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.35",
    "@langchain/langgraph": "^1.2.5",
    "@playwright/browser-chromium": "^1.58.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "langsmith": "^0.5.13",
    "nanoid": "^5.1.7",
    "ora": "^9.3.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vercel": "^50.37.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
