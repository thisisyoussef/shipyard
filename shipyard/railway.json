{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": null
  },
  "deploy": {
    "startCommand": "node --env-file-if-exists=.env ./dist/bin/shipyard.js --ui",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
