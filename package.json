{
  "name": "shipyard",
  "version": "0.1.0",
  "private": true,
  "description": "Persistent coding agent foundation for Shipyard",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "bin": {
    "shipyard": "./dist/bin/shipyard.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --import tsx ./bin/shipyard.ts",
    "shipyard": "node --import tsx ./bin/shipyard.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
